# FI-AI Multi-Agent LLM System — Environment Variables
# Copy this file to .env and adjust values for your environment

# ============================================================
# LLM BACKEND
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Alternative: OpenAI-compatible backend (SGLang/vLLM)
LLM_BACKEND=ollama
OPENAI_COMPAT_BASE_URL=http://localhost:8001/v1
OPENAI_COMPAT_API_KEY=EMPTY
OPENAI_COMPAT_MODEL=Qwen/Qwen2.5-7B-Instruct

# ============================================================
# SLM ROUTER (Intent Classification)
# ============================================================
SLM_ROUTER_ENABLED=false
SLM_ROUTER_MODEL=qwen2.5:1.5b
SLM_ROUTER_TIMEOUT_SECONDS=20
SLM_ROUTER_CONFIDENCE_THRESHOLD=0.0

# ============================================================
# EMBEDDINGS (Vector Search)
# ============================================================
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
CHROMA_DIR=./chroma_db

# ============================================================
# GRAPH DATABASE (Neo4j)
# ============================================================
ENABLE_GRAPH_RAG=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# ============================================================
# CACHE (Redis)
# ============================================================
ENABLE_REDIS_CACHE=true
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.88

# ============================================================
# SESSION MANAGEMENT
# ============================================================
SESSION_TTL_SECONDS=1800
MAX_HISTORY_TURNS=5
SESSION_SUMMARY_THRESHOLD_TOKENS=15

# ============================================================
# CONCURRENCY CONTROL
# ============================================================
MAX_CONCURRENT_LLM_REQUESTS=2
QUEUE_TIMEOUT_SECONDS=60

# ============================================================
# DATA INGESTION (Development)
# ============================================================
ENABLE_WATCH_MODE=false

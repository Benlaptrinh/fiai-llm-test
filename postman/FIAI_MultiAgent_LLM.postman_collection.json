{
  "info": {
    "name": "FI-AI Multi-Agent LLM F&B Assistant",
    "description": "Postman collection for Multi-Agent LLM System for F&B Assistant. Requires running server on localhost:8000 with Ollama, Neo4j, and Redis.\n\n**Prerequisites:**\n1. Start Ollama: `ollama serve`\n2. Start Neo4j: `docker run -p 7474:7474 -p 7687:7687 neo4j:5-community`\n3. Start Redis: `docker run -p 6379:6379 redis:7-alpine`\n4. Pull model: `ollama pull qwen2.5:7b`\n5. Run API: `uvicorn app.main:app --reload --port 8000`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has status field', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('status');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Check API health and system configuration"
      }
    },
    {
      "name": "Chat — Non-Streaming",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Has answer field', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('answer');",
              "});",
              "pm.test('Has intent field', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('intent');",
              "});",
              "pm.test('Has sources field', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('sources');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"query\": \"Cà phê muối giá bao nhiêu?\",\n    \"session_id\": \"test-session-001\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/chat",
          "host": ["{{baseUrl}}"],
          "path": ["chat"]
        },
        "description": "Non-streaming chat — synchronous response"
      }
    },
    {
      "name": "Chat — Streaming (SSE)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Content-Type is text/event-stream', function() {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/event-stream');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"query\": \"Wifi tên gì vậy?\",\n    \"session_id\": \"stream-session-001\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/chat/stream",
          "host": ["{{baseUrl}}"],
          "path": ["chat", "stream"]
        },
        "description": "Streaming chat — SSE token-by-token response. View in Postman's raw body or SSE preview tab."
      }
    },

      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/cache/stats",
          "host": ["{{baseUrl}}"],
          "path": ["cache", "stats"]
        },
        "description": "Get cache hit/miss statistics"
      }
    },
    {
      "name": "Chat — Cache Hit Test",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Second request should be cached', function() {",
              "    var jsonData = pm.response.json();",
              "    // This tests if repeating the same query hits cache",
              "    pm.expect(jsonData).to.have.property('cached');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"query\": \"Wifi tên gì vậy?\",\n    \"session_id\": \"cache-hit-test-session\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/chat",
          "host": ["{{baseUrl}}"],
          "path": ["chat"]
        },
        "description": "Send same query twice to test cache hit on second request. Check 'cached' field in response."
      }
    },
